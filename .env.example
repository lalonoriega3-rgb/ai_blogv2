# .env.example — copia a .env.local y completa los valores

# ── Agentes (backend) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXX
REPLICATE_API_TOKEN=r8_XXXXXXXXXXXXXXXX
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXX
GITHUB_REPO=tu-usuario/ai-blog-agent
BLOG_URL=https://tu-blog.vercel.app

# ── Adsterra (frontend — público) ────────────────────────
# Obtén tus Zone IDs en: publishers.adsterra.com → Sites → Zones
NEXT_PUBLIC_ADSTERRA_HEADER=ZONE_ID_HEADER
NEXT_PUBLIC_ADSTERRA_MID=ZONE_ID_MID
NEXT_PUBLIC_ADSTERRA_NATIVE=ZONE_ID_NATIVE
NEXT_PUBLIC_ADSTERRA_SIDEBAR=ZONE_ID_SIDEBAR
